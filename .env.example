# ============================
# Database Configuration
# ============================
DATABASE_URL=postgresql://user:password@localhost:5432/dn_design_store

# ============================
# API Server Configuration
# ============================
PORT=5000
NODE_ENV=development

# ============================
# CORS Configuration
# ============================
CORS_ORIGIN=http://localhost:3000

# ============================
# Authentication (Better Auth)
# ============================
BETTER_AUTH_SECRET=your_secret_key_here_min_32_chars_long
BETTER_AUTH_URL=http://localhost:5000

# ============================
# Next.js Configuration
# ============================
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# ============================
# Optional: Session/Cookies
# ============================
SESSION_SECRET=your_session_secret_here

# ============================
# Public App URL
# ============================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://e-shop-shopstore.vercel.app

# ============================
# NOWPayments Crypto Checkout
# ============================
# Required for Pay Crypto buttons to create live checkout invoices.
NOWPAYMENTS_API_KEY=your_nowpayments_api_key_here
NOWPAYMENTS_API_URL=https://api.nowpayments.io
NOWPAYMENTS_PRICE_CURRENCY=usd
